@startuml dcmp-paciente
' ============================================================
' C3 - Component Diagram: Paciente Module
' ============================================================

skinparam defaultTextAlignment center
skinparam component {
    BackgroundColor #EFF4FB
    BorderColor #2C5F9E
    FontName Arial
    FontSize 13
}
skinparam interface {
    BackgroundColor #FFFFFF
    BorderColor #2C5F9E
}
skinparam package {
    BackgroundColor #F0F4FF
    BorderColor #4A6FA5
    FontSize 14
}
skinparam ArrowColor #444444
skinparam linetype ortho

package "Paciente Module" {
    interface "HTTP /novo, /psicologos/{id}/pacientes" as API_IF
    
    component "api::paciente" as API <<axum Router>>
    component "services::paciente" as SERVICE <<Business Logic>>
    component "domain::paciente" as DOMAIN <<Models>>
    
    API_IF -down- API
    API -down-> SERVICE : uses
    API -down-> DOMAIN : uses
    SERVICE -down-> DOMAIN : uses
}

component "services::auth" as AUTH_SERVICE <<Hash Password>>
component "services::email" as EMAIL_SERVICE <<Resend>>
database "PostgreSQL" as DB

SERVICE -down-> DB : SQLx queries
SERVICE -down-> AUTH_SERVICE : calls
SERVICE -down-> EMAIL_SERVICE : calls

@enduml
