@startuml dcmp-auth
' ============================================================
' C3 - Component Diagram: Auth Module
' ============================================================

skinparam defaultTextAlignment center
skinparam component {
    BackgroundColor #EFF4FB
    BorderColor #2C5F9E
    FontName Arial
    FontSize 13
}
skinparam interface {
    BackgroundColor #FFFFFF
    BorderColor #2C5F9E
}
skinparam package {
    BackgroundColor #F0F4FF
    BorderColor #4A6FA5
    FontSize 14
}
skinparam ArrowColor #444444
skinparam linetype ortho

package "Auth Module" {
    interface "HTTP /register, /login" as API_IF
    
    component "api::auth" as API <<axum Router>>
    component "services::auth" as SERVICE <<Business Logic>>
    component "domain::user" as DOMAIN <<Models>>
    
    API_IF -down- API
    API -down-> SERVICE : uses
    API -down-> DOMAIN : uses
}

component "events::EventBus" as EVENTS <<Channel>>
database "PostgreSQL" as DB

API -down-> EVENTS : publishes AuthEvent
API -down-> DB : SQLx queries

@enduml
