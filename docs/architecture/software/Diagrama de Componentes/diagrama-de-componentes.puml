@startuml diagrama-de-componentes
' ============================================================
' Diagrama de Componentes – PsiSoft (Nível C3)
' Referência: Craig Larman, Applying UML and Patterns, Cap. 33
' Disciplina: Arquitetura e Desenho de Software (CIC1060) – PUC-GO
' ============================================================

skinparam defaultTextAlignment center
skinparam component {
    BackgroundColor #EFF4FB
    BorderColor #2C5F9E
    FontName Arial
}
skinparam interface {
    BackgroundColor #FFFFFF
    BorderColor #2C5F9E
}
skinparam rectangle {
    BackgroundColor #F0F8FF
    BorderColor #888888
    RoundCorner 12
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}
skinparam ArrowColor #444444
skinparam linetype ortho

' ============================================================
' SUBSISTEMA INTERNO: Plataforma PsiSoft
' ============================================================
rectangle "Plataforma PsiSoft" as PsiSoft {

    component [Frontend UI] as UI
    component [Agendamento] as Agendamento
    component [Consulta] as Consulta
    component [Gestão Financeira] as Financeiro
    component [Notificação] as Notificacao
    component [Prontuário] as Prontuario
    component [Banco de Dados] as BD

    ' --- Interfaces fornecidas (lollipop) ---
    interface "IAgendamento"     as IAgendamento
    interface "IConsulta"        as IConsulta
    interface "IFinanceiro"      as IFinanceiro
    interface "INotificacao"     as INotificacao
    interface "IProntuario"      as IProntuario
    interface "IBancoDeDados"    as IBD

    ' --- Ligações: componente fornece interface ---
    Agendamento  -  IAgendamento
    Consulta     -  IConsulta
    Financeiro   -  IFinanceiro
    Notificacao  -  INotificacao
    Prontuario   -  IProntuario
    BD           -  IBD

    ' --- Ligações: componente usa interface (socket) ---
    ' Frontend requer Agendamento para processar reservas
    UI          ..>  IAgendamento  : <<use>>

    ' Frontend requer Prontuário para exibir/registrar evoluções
    UI          ..>  IProntuario   : <<use>>

    ' Agendamento requer Consulta para registrarConsultaPendente()
    ' (Contrato de Operação 01 – Larman Cap. 11)
    Agendamento ..>  IConsulta     : <<use>>

    ' Consulta requer Financeiro para gerarOrdemCobranca()
    ' (Contrato de Operação 02 – Larman Cap. 11)
    Consulta    ..>  IFinanceiro   : <<use>>

    ' Consulta requer Notificação para agendarLembreteWpp()
    ' (Contrato de Operação 03 – Larman Cap. 11)
    Consulta    ..>  INotificacao  : <<use>>

    ' Consulta e Prontuário persistem no Banco de Dados
    Consulta    ..>  IBD           : <<use>>
    Prontuario  ..>  IBD           : <<use>>
}

' ============================================================
' SERVIÇOS EXTERNOS
' ============================================================
rectangle "Serviços Externos" as Externos {

    component [Gateway de Pagamento] as Gateway
    component [API WhatsApp\n(Meta)] as WhatsApp
    component [API e-Psi\n(CFP)] as ePsi
    component [Motor de IA\n(Transcrição)] as MotorIA

    ' Interfaces fornecidas pelos externos
    interface "IGatewayPagamento" as IGateway
    interface "IWhatsApp"         as IWhatsApp
    interface "IePsi"             as IePsi
    interface "IMotorIA"          as IMotorIA

    Gateway  - IGateway
    WhatsApp - IWhatsApp
    ePsi     - IePsi
    MotorIA  - IMotorIA
}

' ============================================================
' CONECTORES DE MONTAGEM: interno ↔ externo
' (assembly connectors – lollipop + socket)
' ============================================================

' Gestão Financeira ↔ Gateway de Pagamento
' Webhook assíncrono para confirmação de pagamento (RNF-01 – HTTPS/TLS)
Financeiro  ..>  IGateway   : <<use>>

' Notificação ↔ API WhatsApp
' Apenas dados administrativos – proibido conteúdo clínico (RN-02)
Notificacao ..>  IWhatsApp  : <<use>>

' Agendamento ↔ API e-Psi
' Validação do registro do profissional para atendimentos online (RF-05)
Agendamento ..>  IePsi      : <<use>>

' Prontuário ↔ Motor de IA
' Transcrição automática pós-sessão e geração de prontuário (RNF-06)
Prontuario  ..>  IMotorIA   : <<use>>

' ============================================================
' NOTAS ARQUITETURAIS (rastreabilidade com requisitos)
' ============================================================
note right of Agendamento
  processarReserva()
  registrarConsultaPendente()
  Contrato 01 – Larman
  RF-04 | RF-05
end note

note right of Financeiro
  gerarOrdemCobranca()
  efetivarConsulta() via Webhook
  Contratos 02 e 03 – Larman
  RNF-01 (HTTPS/TLS 1.3)
end note

note right of Prontuario
  Guarda obrigatória: 5 anos (RN-01)
  Conforme Res. CFP 001/2009 (RNF-07)
  Criptografia AES-256 (RNF-01)
end note

note right of BD
  Rede privada (VPC) – isolado
  Criptografia AES-256 em repouso
  Backup automático (RNF-03)
end note

@enduml
